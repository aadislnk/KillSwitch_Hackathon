## Backend environment variables (FastAPI)

# Runtime
APP_ENV=development
APP_NAME=KillSwitch API
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# Server
HOST=127.0.0.1
PORT=8000

# Supabase (no auth implemented yet; used later for data storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Scheduler
SCHEDULER_TIMEZONE=UTC

# AI providers (stubs for later)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

