## Monorepo environment template.
## Copy relevant sections into `frontend/.env` and `backend/.env`.

## Frontend (Vite)
VITE_API_BASE_URL=http://127.0.0.1:8000

## Backend (FastAPI)
APP_ENV=development
APP_NAME=KillSwitch API
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO
HOST=127.0.0.1
PORT=8000
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SCHEDULER_TIMEZONE=UTC
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

